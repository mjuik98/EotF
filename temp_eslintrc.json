{
    "env": {
        "browser": true,
        "es2021": true
    },
    "parserOptions": {
        "sourceType": "module",
        "ecmaVersion": "latest"
    },
    "rules": {
        "no-undef": "error",
        "no-unused-vars": "warn"
    },
    "globals": {
        "GAME": "readonly",
        "DATA": "readonly",
        "GS": "readonly",
        "window": "readonly",
        "document": "readonly",
        "console": "readonly",
        "setTimeout": "readonly",
        "clearTimeout": "readonly",
        "setInterval": "readonly",
        "clearInterval": "readonly",
        "requestAnimationFrame": "readonly",
        "cancelAnimationFrame": "readonly",
        "localStorage": "readonly",
        "Math": "readonly",
        "Object": "readonly",
        "Array": "readonly",
        "String": "readonly",
        "Number": "readonly",
        "Boolean": "readonly",
        "Promise": "readonly",
        "Error": "readonly",
        "Date": "readonly",
        "parseFloat": "readonly",
        "parseInt": "readonly",
        "isNaN": "readonly",
        "Map": "readonly",
        "Set": "readonly",
        "JSON": "readonly"
    }
}