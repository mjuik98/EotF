{
  "name": "echo-of-the-fallen",
  "version": "2.0.0",
  "description": "Roguelike Deckbuilder Game",
  "type": "module",
  "main": "index.html",
  "scripts": {
    "clean": "node scripts/clean-generated.mjs",
    "clean:smoke": "node scripts/clean-generated.mjs --smoke",
    "dev": "vite",
    "build": "vite build && node scripts/assert-bundle-budgets.mjs",
    "preview": "vite preview",
    "lint": "node scripts/test_suite_manifest.mjs --check && node scripts/check-architecture.mjs && node scripts/check-feature-structure.mjs && node scripts/check-compat-surface.mjs && node scripts/check-canonical-feature-imports.mjs && node scripts/check-deprecated-compat-imports.mjs && node scripts/check-compat-public-entrypoints.mjs && node scripts/check-legacy-global-access.mjs && node scripts/check-window-usage.mjs && node scripts/check-state-mutations.mjs && node scripts/check-event-contracts.mjs && node scripts/check-import-coupling.mjs && node scripts/check-content-data.mjs",
    "test": "node scripts/run-vitest-suite.mjs fast",
    "test:guardrails": "node scripts/run-vitest-suite.mjs guardrails",
    "test:full": "node scripts/run-vitest-suite.mjs full",
    "test:slow-report": "node scripts/report-slow-tests.mjs --suite fast",
    "test:order-guard": "node scripts/check-vitest-order-dependence.mjs fast",
    "test:manifest": "node scripts/test_suite_manifest.mjs --check",
    "test:manifest:write": "node scripts/test_suite_manifest.mjs --write",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest",
    "deps:map": "node scripts/generate-dependency-map.mjs",
    "deps:map:check": "node scripts/generate-dependency-map.mjs --check",
    "deps:threshold": "node scripts/check-dependency-delta-threshold.mjs",
    "audit:structure": "node scripts/report-structural-audit.mjs --strict",
    "audit:transition-surfaces": "node scripts/report-transition-surface-audit.mjs",
    "check:data": "node scripts/check-content-data.mjs",
    "smoke:character-select": "node scripts/run_character_select_smoke.mjs",
    "smoke:reward": "node scripts/run_reward_smoke.mjs",
    "smoke:combat-ui": "node scripts/run_combat_ui_smoke.mjs",
    "smoke:save-load": "node scripts/save_load_roundtrip_smoke_check.mjs",
    "smoke:save-outbox-recovery": "node scripts/save_outbox_recovery_smoke_check.mjs",
    "smoke:browser": "node scripts/run_browser_smoke_suite.mjs",
    "quality:sync": "npm run test:manifest:write && npm run deps:map",
    "quality:fast": "npm run lint && npm test",
    "quality:full": "npm run lint && npm run test:coverage && npm run audit:structure && npm run deps:map:check && npm run test:order-guard -- --runs 1 --sample 20 && npm run test:slow-report && npm run build && npm run smoke:browser",
    "quality": "npm run quality:full"
  },
  "keywords": [
    "game",
    "roguelike",
    "deckbuilder"
  ],
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "@vitest/coverage-v8": "^3.2.4",
    "playwright": "^1.58.2",
    "vite": "^7.3.1",
    "vitest": "^3.2.4"
  },
  "dependencies": {
    "acorn": "^8.16.0"
  }
}
