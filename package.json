{
  "name": "echo-of-the-fallen",
  "version": "2.0.0",
  "description": "Roguelike Deckbuilder Game",
  "type": "module",
  "main": "index.html",
  "scripts": {
    "clean": "node scripts/clean-generated.mjs",
    "clean:smoke": "node scripts/clean-generated.mjs --smoke",
    "dev": "vite",
    "build": "vite build && node scripts/assert-bundle-budgets.mjs",
    "preview": "vite preview",
    "lint": "node scripts/check-architecture.mjs && node scripts/check-feature-structure.mjs && node scripts/check-compat-surface.mjs && node scripts/check-legacy-global-access.mjs && node scripts/check-window-usage.mjs && node scripts/check-state-mutations.mjs && node scripts/check-event-contracts.mjs && node scripts/check-import-coupling.mjs && node scripts/check-content-data.mjs",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest",
    "deps:map": "node scripts/generate-dependency-map.mjs",
    "deps:threshold": "node scripts/check-dependency-delta-threshold.mjs",
    "audit:structure": "node scripts/report-structural-audit.mjs",
    "check:data": "node scripts/check-content-data.mjs",
    "smoke:reward": "node scripts/run_reward_smoke.mjs",
    "smoke:combat-ui": "node scripts/run_combat_ui_smoke.mjs",
    "quality": "npm run lint && npm run test:coverage && npm run build"
  },
  "keywords": [
    "game",
    "roguelike",
    "deckbuilder"
  ],
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "@vitest/coverage-v8": "^3.2.4",
    "playwright": "^1.58.2",
    "vite": "^7.3.1",
    "vitest": "^3.2.4"
  },
  "dependencies": {
    "acorn": "^8.16.0"
  }
}
