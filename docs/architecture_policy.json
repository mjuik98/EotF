{
  "scanDirs": ["game", "engine", "data"],
  "layerMatchers": [
    { "layer": "app", "prefix": "game/app/" },
    { "layer": "domain", "prefix": "game/domain/" },
    { "layer": "feature", "prefix": "game/features/" },
    { "layer": "state", "prefix": "game/state/" },
    { "layer": "presentation", "prefix": "game/presentation/" },
    { "layer": "shared", "prefix": "game/shared/" },
    { "layer": "legacy", "prefix": "game/platform/legacy/" },
    { "layer": "platform", "prefix": "game/platform/" },
    { "layer": "ui", "prefix": "game/ui/" },
    { "layer": "combat", "prefix": "game/combat/" },
    { "layer": "systems", "prefix": "game/systems/" },
    { "layer": "core", "prefix": "game/core/" },
    { "layer": "utils", "prefix": "game/utils/" },
    { "layer": "engine", "prefix": "engine/" },
    { "layer": "data", "prefix": "data/" }
  ],
  "rules": [
    {
      "id": "domain-no-ui",
      "from": ["systems", "combat", "utils"],
      "to": ["ui"],
      "message": "systems/combat/utils must not import ui"
    },
    {
      "id": "core-ui-composition-root-only",
      "from": ["core"],
      "to": ["ui"],
      "allowSources": [
        "game/core/main.js",
        "game/core/event_bindings.js",
        "game/core/init_sequence.js",
        "game/core/deps_factory.js"
      ],
      "allowSourcePrefixes": ["game/core/bindings/", "game/core/composition/"],
      "message": "core file outside composition root importing ui"
    },
    {
      "id": "ui-no-core-composition-root",
      "from": ["ui"],
      "denyTargets": [
        "game/core/main.js",
        "game/core/event_bindings.js"
      ],
      "message": "ui must not import core composition root"
    },
    {
      "id": "engine-data-no-ui",
      "from": ["engine", "data"],
      "to": ["ui"],
      "message": "engine/data must not import ui"
    },
    {
      "id": "app-no-ui",
      "from": ["app"],
      "to": ["ui"],
      "message": "app must not import ui"
    },
    {
      "id": "app-no-legacy",
      "from": ["app"],
      "to": ["legacy"],
      "message": "app must not import legacy directly"
    },
    {
      "id": "app-no-combat",
      "from": ["app"],
      "to": ["combat"],
      "message": "app must use feature/domain entry points instead of legacy combat modules"
    },
    {
      "id": "app-no-direct-event-manager",
      "from": ["app"],
      "denyTargets": [
        "game/systems/event_manager.js"
      ],
      "message": "app event flows must import feature event actions instead of the legacy event manager"
    },
    {
      "id": "ui-no-direct-domain-state-systems",
      "from": ["ui"],
      "denyTargets": [
        "game/systems/event_manager.js",
        "game/systems/codex_records_system.js",
        "game/systems/class_progression_system.js",
        "game/core/game_state_defaults.js"
      ],
      "message": "ui must use app/state entry points instead of direct domain/system imports"
    },
    {
      "id": "non-core-state-actions-shared-only",
      "from": ["app", "combat", "domain", "feature", "legacy", "ui"],
      "denyTargets": [
        "game/core/state_actions.js"
      ],
      "message": "non-core layers must import state actions through game/shared/state/public.js"
    },
    {
      "id": "platform-no-direct-ui-feature-facades",
      "from": ["platform"],
      "denyTargets": [
        "game/ui/screens/event_ui.js",
        "game/ui/screens/reward_ui.js",
        "game/ui/combat/combat_turn_ui.js"
      ],
      "message": "platform composition should import feature facades through presentation boundaries"
    },
    {
      "id": "platform-title-flow-public-only",
      "from": ["platform"],
      "sourceFiles": [
        "game/platform/browser/composition/build_title_flow_modules.js"
      ],
      "denyTargetPrefixes": [
        "game/ui/title/"
      ],
      "message": "title flow composition must import the title feature public facade instead of title ui internals"
    },
    {
      "id": "platform-title-canvas-public-only",
      "from": ["platform"],
      "sourceFiles": [
        "game/platform/browser/composition/build_title_canvas_modules.js"
      ],
      "denyTargetPrefixes": [
        "game/ui/title/"
      ],
      "message": "title canvas composition must import the title feature public facade instead of title ui internals"
    },
    {
      "id": "platform-run-map-public-only",
      "from": ["platform"],
      "sourceFiles": [
        "game/platform/browser/composition/build_run_map_modules.js"
      ],
      "denyTargetPrefixes": [
        "game/ui/map/"
      ],
      "message": "run map composition must import the run feature public facade instead of map ui internals"
    },
    {
      "id": "platform-run-flow-public-only",
      "from": ["platform"],
      "sourceFiles": [
        "game/platform/browser/composition/build_run_flow_modules.js"
      ],
      "denyTargetPrefixes": [
        "game/ui/run/"
      ],
      "message": "run flow composition must import the run feature public facade instead of run ui internals"
    },
    {
      "id": "core-init-sequence-legacy-platform-only",
      "from": ["core"],
      "sourceFiles": [
        "game/core/init_sequence.js"
      ],
      "denyTargets": [
        "game/core/bootstrap/register_legacy_surface.js"
      ],
      "message": "core init sequence must register the legacy bridge through platform/legacy"
    },
    {
      "id": "title-public-module-catalog-only",
      "from": ["feature"],
      "sourceFiles": [
        "game/features/title/public.js"
      ],
      "denyTargetPrefixes": [
        "game/ui/title/"
      ],
      "message": "title public surface must use a feature-local module catalog instead of direct ui imports"
    },
    {
      "id": "run-public-module-catalog-only",
      "from": ["feature"],
      "sourceFiles": [
        "game/features/run/modules/public_run_modules.js"
      ],
      "denyTargetPrefixes": [
        "game/ui/map/",
        "game/ui/run/"
      ],
      "message": "run public surface must use a feature-local module catalog instead of direct ui imports"
    },
    {
      "id": "ui-map-navigation-feature-boundary",
      "from": ["ui"],
      "sourceFiles": [
        "game/ui/map/map_navigation_ui.js"
      ],
      "denyTargetPrefixes": [
        "game/app/",
        "game/core/",
        "game/domain/",
        "game/data/",
        "data/"
      ],
      "message": "map navigation ui must delegate navigation policy through feature/application boundaries"
    },
    {
      "id": "ui-title-mount-feature-boundary",
      "from": ["ui"],
      "sourceFiles": [
        "game/ui/title/character_select_mount_runtime.js"
      ],
      "denyTargetPrefixes": [
        "game/app/",
        "game/core/",
        "game/data/",
        "data/"
      ],
      "message": "character select mount ui must delegate catalog/progression work through feature boundaries"
    },
    {
      "id": "ui-title-class-select-feature-boundary",
      "from": ["ui"],
      "sourceFiles": [
        "game/ui/title/class_select_ui.js"
      ],
      "denyTargetPrefixes": [
        "game/app/",
        "game/core/",
        "game/data/",
        "data/"
      ],
      "message": "class select ui must delegate selection state and metadata through feature boundaries"
    },
    {
      "id": "ui-run-start-feature-boundary",
      "from": ["ui"],
      "sourceFiles": [
        "game/ui/run/run_start_ui.js",
        "game/ui/run/run_start_ui_runtime.js"
      ],
      "denyTargetPrefixes": [
        "game/app/",
        "game/core/",
        "game/ui/effects/"
      ],
      "message": "run start ui must delegate transition orchestration through feature run application/runtime boundaries"
    },
    {
      "id": "ui-run-setup-feature-boundary",
      "from": ["ui"],
      "sourceFiles": [
        "game/ui/run/run_setup_ui.js",
        "game/ui/run/run_setup_ui_runtime.js",
        "game/ui/run/run_setup_helpers.js"
      ],
      "denyTargetPrefixes": [
        "game/app/",
        "game/core/"
      ],
      "message": "run setup ui must delegate setup orchestration through feature run application boundaries"
    },
    {
      "id": "ui-character-select-flow-feature-boundary",
      "from": ["ui"],
      "sourceFiles": [
        "game/ui/title/character_select_flow.js"
      ],
      "denyTargetPrefixes": [
        "game/app/"
      ],
      "message": "character select flow must delegate confirm sequencing through title feature application boundaries"
    },
    {
      "id": "feature-title-flow-no-app-title-use-cases",
      "from": ["feature"],
      "sourceFiles": [
        "game/features/title/app/title_flow_actions.js"
      ],
      "denyTargetPrefixes": [
        "game/app/title/use_cases/"
      ],
      "message": "title flow actions must use title feature application entry points instead of app/title use cases"
    },
    {
      "id": "core-mount-character-select-feature-actions-only",
      "from": ["core"],
      "sourceFiles": [
        "game/core/bootstrap/mount_character_select.js"
      ],
      "denyTargetPrefixes": [
        "game/app/",
        "game/features/title/application/",
        "game/ui/title/"
      ],
      "message": "mount_character_select must wire through title feature actions instead of screen-local semantics"
    },
    {
      "id": "feature-run-flow-contracts-runtime-only",
      "from": ["feature"],
      "sourceFiles": [
        "game/features/run/ports/contracts/build_run_flow_contracts.js"
      ],
      "denyTargetPrefixes": [
        "game/ui/run/"
      ],
      "message": "run flow contracts must assemble gameplay handoff through run feature runtimes instead of run ui facades"
    },
    {
      "id": "feature-run-map-actions-handoff-contract-only",
      "from": ["feature"],
      "sourceFiles": [
        "game/features/run/app/run_map_actions.js",
        "game/features/run/presentation/present_node_transition.js"
      ],
      "denyTargetPrefixes": [
        "game/features/combat/",
        "game/features/event/",
        "game/features/reward/",
        "game/ui/combat/",
        "game/ui/screens/"
      ],
      "message": "run map actions and presenters must hand off to combat/event/reward through contracts instead of direct feature or ui imports"
    },
    {
      "id": "platform-combat-core-public-only",
      "from": ["platform"],
      "sourceFiles": [
        "game/platform/browser/composition/build_combat_core_modules.js"
      ],
      "denyTargetPrefixes": [
        "game/ui/combat/",
        "game/presentation/combat/"
      ],
      "message": "combat core composition must import the combat feature public facade instead of combat internals"
    },
    {
      "id": "platform-combat-card-public-only",
      "from": ["platform"],
      "sourceFiles": [
        "game/platform/browser/composition/build_combat_card_modules.js"
      ],
      "denyTargetPrefixes": [
        "game/ui/cards/"
      ],
      "message": "combat card composition must import the combat feature public facade instead of card ui internals"
    },
    {
      "id": "platform-combat-hud-public-only",
      "from": ["platform"],
      "sourceFiles": [
        "game/platform/browser/composition/build_combat_hud_modules.js"
      ],
      "denyTargetPrefixes": [
        "game/ui/hud/"
      ],
      "message": "combat hud composition must import the combat feature public facade instead of hud ui internals"
    },
    {
      "id": "core-ui-bindings-public-only",
      "from": ["core"],
      "sourceFiles": [
        "game/core/bindings/ui_bindings.js"
      ],
      "denyTargetPrefixes": [
        "game/features/ui/app/",
        "game/features/ui/ports/"
      ],
      "message": "core ui bindings must import the ui feature public facade instead of ui internals"
    },
    {
      "id": "core-title-bindings-public-only",
      "from": ["core"],
      "sourceFiles": [
        "game/core/bindings/title_settings_bindings.js"
      ],
      "denyTargetPrefixes": [
        "game/features/title/app/",
        "game/features/title/ports/"
      ],
      "message": "core title bindings must import the title feature public facade instead of title internals"
    },
    {
      "id": "core-combat-bindings-public-only",
      "from": ["core"],
      "sourceFiles": [
        "game/core/bindings/combat_bindings.js"
      ],
      "denyTargetPrefixes": [
        "game/features/combat/app/",
        "game/features/combat/ports/"
      ],
      "message": "core combat bindings must import the combat feature public facade instead of combat internals"
    },
    {
      "id": "core-run-canvas-bindings-public-only",
      "from": ["core"],
      "sourceFiles": [
        "game/core/bindings/canvas_bindings.js"
      ],
      "denyTargetPrefixes": [
        "game/features/run/app/",
        "game/features/run/ports/"
      ],
      "message": "core run canvas bindings must import the run feature public facade instead of run internals"
    },
    {
      "id": "core-event-reward-bindings-public-only",
      "from": ["core"],
      "sourceFiles": [
        "game/core/bindings/event_reward_bindings_runtime.js"
      ],
      "denyTargetPrefixes": [
        "game/features/event/app/",
        "game/features/event/ports/"
      ],
      "message": "core event/reward bindings must import the event feature public facade instead of event internals"
    },
    {
      "id": "core-runtime-subscriber-public-only",
      "from": ["core"],
      "sourceFiles": [
        "game/core/bootstrap/build_runtime_subscriber_action_groups.js"
      ],
      "denyTargetPrefixes": [
        "game/features/combat/app/",
        "game/features/ui/app/"
      ],
      "message": "core runtime subscriber groups must import feature public facades instead of subscriber internals"
    },
    {
      "id": "core-game-boot-public-only",
      "from": ["core"],
      "sourceFiles": [
        "game/core/bootstrap/build_game_boot_action_groups.js"
      ],
      "denyTargetPrefixes": [
        "game/features/run/app/",
        "game/features/title/app/"
      ],
      "message": "core game boot groups must import feature public facades instead of boot internals"
    },
    {
      "id": "core-ui-contract-builders-public-only",
      "from": ["core"],
      "sourceFiles": [
        "game/core/deps/contracts/ui_contract_builders.js"
      ],
      "denyTargetPrefixes": [
        "game/features/combat/ports/contracts/",
        "game/features/run/ports/contracts/",
        "game/features/ui/ports/contracts/"
      ],
      "message": "core ui contract builders must import feature public facades instead of contract internals"
    },
    {
      "id": "core-run-contract-builders-public-only",
      "from": ["core"],
      "sourceFiles": [
        "game/core/deps/contracts/run_contract_builders.js"
      ],
      "denyTargetPrefixes": [
        "game/features/run/ports/contracts/",
        "game/features/title/ports/contracts/"
      ],
      "message": "core run contract builders must import feature public facades instead of contract internals"
    },
    {
      "id": "legacy-combat-card-public-only",
      "from": ["legacy"],
      "sourceFiles": [
        "game/platform/legacy/game_api/combat_commands.js",
        "game/platform/legacy/game_api/player_draw_commands.js"
      ],
      "denyTargetPrefixes": [
        "game/features/combat/app/",
        "game/app/combat/"
      ],
      "message": "legacy combat game api must import the combat feature public facade instead of combat internals"
    },
    {
      "id": "legacy-combat-compat-public-only",
      "from": ["legacy"],
      "sourceFiles": [
        "game/platform/legacy/adapters/create_legacy_combat_compat.js"
      ],
      "denyTargetPrefixes": [
        "game/features/combat/ports/"
      ],
      "message": "legacy combat compat adapter must import the combat feature public facade instead of combat ports internals"
    },
    {
      "id": "legacy-window-ui-query-public-only",
      "from": ["legacy"],
      "sourceFiles": [
        "game/platform/legacy/build_legacy_window_ui_query_groups.js"
      ],
      "denyTargets": [
        "game/platform/legacy/adapters/create_legacy_combat_compat.js"
      ],
      "message": "legacy window ui query groups must import feature public facades instead of legacy adapter internals"
    },
    {
      "id": "legacy-runtime-query-ui-public-only",
      "from": ["legacy"],
      "sourceFiles": [
        "game/platform/legacy/build_legacy_game_api_runtime_query_groups.js",
        "game/platform/legacy/game_api/ui_commands.js"
      ],
      "denyTargetPrefixes": [
        "game/ui/"
      ],
      "message": "legacy runtime query and ui command surfaces must import feature public facades instead of ui internals"
    },
    {
      "id": "legacy-module-query-shared-runtime-only",
      "from": ["legacy"],
      "sourceFiles": [
        "game/platform/legacy/game_api_module_queries.js",
        "game/platform/legacy/window_binding_utility_queries.js"
      ],
      "denyTargetPrefixes": [
        "game/features/",
        "game/ui/"
      ],
      "message": "legacy module and utility query surfaces must import shared runtime public bindings instead of feature or ui internals"
    },
    {
      "id": "legacy-game-api-facade-payload-only",
      "from": ["legacy"],
      "sourceFiles": [
        "game/platform/legacy/game_api_facade.js"
      ],
      "denyTargets": [
        "game/platform/legacy/game_api_player_facade.js",
        "game/platform/legacy/game_api_combat_facade.js",
        "game/platform/legacy/game_api_screen_facade.js",
        "game/platform/legacy/game_api_ui_facade.js"
      ],
      "message": "legacy game api facade must assemble through the compat payload builder instead of direct facade composition"
    },
    {
      "id": "legacy-game-api-registry-builder-only",
      "from": ["legacy"],
      "sourceFiles": [
        "game/platform/legacy/game_api_registry.js"
      ],
      "denyTargets": [
        "game/platform/legacy/game_api_compat.js",
        "game/platform/legacy/game_api_facade.js"
      ],
      "message": "legacy game api registry must assemble from bindings and payload builders instead of compat facades"
    },
    {
      "id": "legacy-game-api-registry-registration-payload-only",
      "from": ["legacy"],
      "sourceFiles": [
        "game/platform/legacy/game_api_registry.js"
      ],
      "denyTargets": [
        "game/platform/legacy/game_api_command_bindings.js",
        "game/platform/legacy/game_api_query_bindings.js",
        "game/platform/legacy/build_legacy_game_api_payload.js"
      ],
      "message": "legacy game api registry must compose registration data through the legacy payload builder"
    },
    {
      "id": "legacy-game-api-payload-shared-runtime-only",
      "from": ["legacy"],
      "sourceFiles": [
        "game/platform/legacy/build_legacy_game_api_payload.js"
      ],
      "denyTargetPrefixes": [
        "game/features/",
        "game/ui/",
        "game/platform/legacy/game_api/"
      ],
      "message": "legacy game api payload builder must rely on shared runtime grouping instead of direct feature or action implementation imports"
    },
    {
      "id": "legacy-window-query-merge-shared-runtime-only",
      "from": ["legacy"],
      "sourceFiles": [
        "game/platform/legacy/window_binding_queries.js"
      ],
      "denyTargetPrefixes": [
        "game/features/",
        "game/ui/"
      ],
      "message": "legacy window query attachment must merge shared/public query groups instead of direct feature or ui internals"
    },
    {
      "id": "legacy-window-bindings-payload-only",
      "from": ["legacy"],
      "sourceFiles": [
        "game/platform/legacy/window_bindings.js"
      ],
      "denyTargets": [
        "game/platform/legacy/resolve_legacy_window_binding_root.js",
        "game/platform/legacy/build_legacy_window_binding_steps.js"
      ],
      "message": "legacy window bindings must build root and step payloads through the legacy payload builder"
    },
    {
      "id": "legacy-screen-commands-core-service-only",
      "from": ["legacy"],
      "sourceFiles": [
        "game/platform/legacy/game_api/screen_commands.js"
      ],
      "denyTargets": [
        "game/app/system/screen_service.js"
      ],
      "message": "legacy screen commands must import the core screen service directly instead of the app compat alias"
    }
  ]
}
