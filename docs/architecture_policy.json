{
  "scanDirs": ["game", "engine", "data"],
  "layerMatchers": [
    { "layer": "app", "prefix": "game/app/" },
    { "layer": "domain", "prefix": "game/domain/" },
    { "layer": "feature", "prefix": "game/features/" },
    { "layer": "state", "prefix": "game/state/" },
    { "layer": "presentation", "prefix": "game/presentation/" },
    { "layer": "shared", "prefix": "game/shared/" },
    { "layer": "legacy", "prefix": "game/platform/legacy/" },
    { "layer": "platform", "prefix": "game/platform/" },
    { "layer": "ui", "prefix": "game/ui/" },
    { "layer": "combat", "prefix": "game/combat/" },
    { "layer": "systems", "prefix": "game/systems/" },
    { "layer": "core", "prefix": "game/core/" },
    { "layer": "utils", "prefix": "game/utils/" },
    { "layer": "engine", "prefix": "engine/" },
    { "layer": "data", "prefix": "data/" }
  ],
  "rules": [
    {
      "id": "domain-no-ui",
      "from": ["systems", "combat", "utils"],
      "to": ["ui"],
      "message": "systems/combat/utils must not import ui"
    },
    {
      "id": "domain-layer-no-ui",
      "from": ["domain"],
      "to": ["ui"],
      "message": "domain must not import ui"
    },
    {
      "id": "shared-layer-no-platform",
      "from": ["shared"],
      "to": ["platform"],
      "message": "shared must not import platform"
    },
    {
      "id": "core-ui-composition-root-only",
      "from": ["core"],
      "to": ["ui"],
      "allowSources": [
        "game/core/main.js",
        "game/core/event_bindings.js",
        "game/core/init_sequence.js",
        "game/core/deps_factory.js"
      ],
      "allowSourcePrefixes": ["game/core/bindings/", "game/core/composition/"],
      "message": "core file outside composition root importing ui"
    },
    {
      "id": "ui-no-core-composition-root",
      "from": ["ui"],
      "denyTargets": [
        "game/core/main.js",
        "game/core/event_bindings.js"
      ],
      "message": "ui must not import core composition root"
    },
    {
      "id": "engine-data-no-ui",
      "from": ["engine", "data"],
      "to": ["ui"],
      "message": "engine/data must not import ui"
    },
    {
      "id": "app-no-ui",
      "from": ["app"],
      "to": ["ui"],
      "message": "app must not import ui"
    },
    {
      "id": "app-no-legacy",
      "from": ["app"],
      "to": ["legacy"],
      "message": "app must not import legacy directly"
    },
    {
      "id": "app-no-combat",
      "from": ["app"],
      "to": ["combat"],
      "message": "app must use feature/domain entry points instead of legacy combat modules"
    },
    {
      "id": "app-no-direct-event-manager",
      "from": ["app"],
      "denyTargets": [
        "game/systems/event_manager.js"
      ],
      "message": "app event flows must import feature event actions instead of the legacy event manager"
    },
    {
      "id": "ui-no-direct-domain-state-systems",
      "from": ["ui"],
      "denyTargets": [
        "game/systems/event_manager.js",
        "game/systems/codex_records_system.js",
        "game/systems/class_progression_system.js",
        "game/core/game_state_defaults.js"
      ],
      "message": "ui must use app/state entry points instead of direct domain/system imports"
    },
    {
      "id": "non-core-state-actions-shared-only",
      "from": ["app", "combat", "domain", "feature", "legacy", "ui"],
      "denyTargets": [
        "game/core/state_actions.js"
      ],
      "message": "non-core layers must import state actions through game/shared/state/public.js"
    },
    {
      "id": "feature-no-app-compat-imports",
      "from": ["feature"],
      "denyTargetPrefixes": [
        "game/app/"
      ],
      "message": "feature implementation must not import game/app compat paths"
    },
    {
      "id": "feature-no-core-global-bridge",
      "from": ["feature"],
      "denyTargets": [
        "game/core/global_bridge.js"
      ],
      "message": "feature implementation must use platform or legacy ports instead of importing the core global bridge directly"
    },
    {
      "id": "feature-no-class-progression-system-compat",
      "from": ["feature"],
      "denyTargets": [
        "game/systems/class_progression_system.js"
      ],
      "message": "feature implementation must use title feature or shared progression ownership instead of the class progression compat surface"
    },
    {
      "id": "feature-no-codex-record-system-compat",
      "from": ["feature"],
      "denyTargets": [
        "game/systems/codex_records_system.js"
      ],
      "message": "feature implementation must use shared codex ownership instead of the codex records compat surface"
    },
    {
      "id": "feature-no-run-rules-systems-compat",
      "from": ["feature"],
      "denyTargets": [
        "game/systems/run_rules_curses.js",
        "game/systems/run_rules_regions.js",
        "game/systems/run_rules_difficulty.js",
        "game/systems/run_rules_meta.js"
      ],
      "message": "feature implementation must use run feature domain ownership instead of the run-rules systems compat surface"
    },
    {
      "id": "reward-application-platform-boundary",
      "from": ["feature"],
      "sourcePrefixes": [
        "game/features/reward/application/"
      ],
      "denyTargetPrefixes": [
        "game/ui/",
        "game/presentation/"
      ],
      "message": "reward application must use platform/runtime ports instead of ui or presentation modules"
    },
    {
      "id": "reward-presentation-feature-runtime-only",
      "from": ["presentation"],
      "sourceFiles": [
        "game/presentation/screens/reward_ui.js"
      ],
      "denyTargetPrefixes": [
        "game/ui/"
      ],
      "message": "reward presentation must use the reward feature runtime instead of ui screen runtimes directly"
    },
    {
      "id": "event-application-platform-boundary",
      "from": ["feature"],
      "sourcePrefixes": [
        "game/features/event/application/"
      ],
      "denyTargetPrefixes": [
        "game/ui/",
        "game/presentation/"
      ],
      "message": "event application must use platform/runtime ports instead of ui or presentation modules"
    },
    {
      "id": "combat-start-application-platform-boundary",
      "from": ["feature"],
      "sourceFiles": [
        "game/features/combat/application/create_combat_start_runtime.js"
      ],
      "denyTargetPrefixes": [
